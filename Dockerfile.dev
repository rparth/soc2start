# Multi-stage dev build: Node (frontend) → Go (backend) → Ubuntu (runtime)
# Usage: docker compose build && docker compose up -d

ARG BASE_IMAGE=ubuntu:24.04@sha256:c4a8d5503dfb2a3eb8ab5f807da5bc69a85730fb49b5cfca2330194ebcc41c7b

# --- Stage 1: Build frontend assets ---
FROM node:22-bookworm-slim AS node-builder
WORKDIR /app

COPY package.json package-lock.json turbo.json relay.config.json ./
COPY apps/ apps/
COPY packages/ packages/
COPY examples/ examples/
RUN npm ci

COPY contrib/merge-graphql-schema.sh contrib/
COPY pkg/server/api/connect/v1/graphql/ pkg/server/api/connect/v1/graphql/
COPY pkg/server/api/console/v1/graphql/ pkg/server/api/console/v1/graphql/
COPY pkg/server/api/trust/v1/graphql/ pkg/server/api/trust/v1/graphql/
RUN chmod +x contrib/merge-graphql-schema.sh && \
    contrib/merge-graphql-schema.sh pkg/server/api/connect/v1/schema.graphql pkg/server/api/connect/v1/graphql && \
    contrib/merge-graphql-schema.sh pkg/server/api/console/v1/schema.graphql pkg/server/api/console/v1/graphql && \
    contrib/merge-graphql-schema.sh pkg/server/api/trust/v1/schema.graphql pkg/server/api/trust/v1/graphql

RUN npx relay-compiler
RUN NODE_ENV=production npm --workspace @probo/console run build
RUN NODE_ENV=production npm --workspace @probo/trust run build
RUN npm --workspace @probo/emails run build

# --- Stage 2: Build Go backend with embedded frontend ---
FROM golang:1.26-bookworm AS go-builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

COPY --from=node-builder /app/pkg/server/api/connect/v1/schema.graphql pkg/server/api/connect/v1/schema.graphql
COPY --from=node-builder /app/pkg/server/api/console/v1/schema.graphql pkg/server/api/console/v1/schema.graphql
COPY --from=node-builder /app/pkg/server/api/trust/v1/schema.graphql pkg/server/api/trust/v1/schema.graphql
COPY --from=node-builder /app/apps/console/dist/ apps/console/dist/
COPY --from=node-builder /app/apps/trust/dist/ apps/trust/dist/
COPY --from=node-builder /app/packages/emails/dist/ packages/emails/dist/

RUN go generate ./pkg/server/api/connect/v1
RUN go generate ./pkg/server/api/console/v1
RUN go generate ./pkg/server/api/trust/v1
RUN go generate ./pkg/server/api/mcp/v1

ARG VERSION=dev
RUN CGO_ENABLED=0 go build -gcflags="-e" \
    -ldflags "-X 'main.version=${VERSION}' -X 'main.env=dev'" \
    -o bin/soc2startd cmd/soc2startd/main.go
RUN CGO_ENABLED=0 go build -gcflags="-e" \
    -ldflags "-X 'main.version=${VERSION}'" \
    -o bin/soc2startd-bootstrap cmd/soc2startd-bootstrap/main.go

# --- Stage 3: Runtime ---
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

RUN useradd -m probo && \
    apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y ca-certificates libcap2-bin openssl && \
    rm -rf /var/lib/apt/lists/*

COPY --from=go-builder /app/bin/soc2startd /usr/local/bin/soc2startd
COPY --from=go-builder /app/bin/soc2startd-bootstrap /usr/local/bin/soc2startd-bootstrap
COPY entrypoint.sh /usr/local/bin/entrypoint.sh

RUN chmod +x /usr/local/bin/soc2startd && \
    chmod +x /usr/local/bin/soc2startd-bootstrap && \
    chmod +x /usr/local/bin/entrypoint.sh && \
    setcap CAP_NET_BIND_SERVICE=+eip /usr/local/bin/soc2startd && \
    mkdir -p /etc/soc2startd && \
    chown probo:probo /etc/soc2startd

USER probo

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
